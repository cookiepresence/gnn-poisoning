# Core
seed = 42
device = auto

# Dataset
dataset-name = amazon
dataset-variant = Computers
dataset-root = artifacts/data/amazon-computers
dataset-normalize-features = true

# Model (GCN)
model-name = gcn
hidden-dim = 256
num-layers = 3
dropout = 0.0
heads = 8

# Attack
attack-name = mg
attack-flip-frac = 0.1
attack-target-label = none
attack-seed = 42

mg-n-iter = 2
mg-attack-prop = SK
mg-pred-prop = SK
mg-gamma = 1.0
mg-pagerank-alpha = 0.1
mg-prop-k = 2

# Train
epochs = 400
lr = 0.01
weight-decay = 0.0
eval-every = 5

# Logging
run-dir = artifacts/runs
run-name = amazon-computers__mg
save-best = true
wandb-enable = true
wandb-project = gnn-label-poisoning
wandb-tags = amazon_computers,mg
