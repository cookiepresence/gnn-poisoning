# Core
seed = 42
device = auto

# Dataset
dataset-name = amazon
dataset-variant = Computers
dataset-root = artifacts/data/amazon-computers
dataset-normalize-features = true

# Model (GCN)
model-name = gcn
hidden-dim = 256
num-layers = 3
dropout = 0.0
heads = 8

# Attack
attack-name = lafak
attack-flip-frac = 0.1
attack-target-label = none
attack-seed = 42
lafak-atk-epochs = 200
lafak-gcn-l2 = 5e-4
lafak-lr = 1e-4

# Train
epochs = 400
lr = 0.01
weight-decay = 0.0
eval-every = 5

# Logging
run-dir = artifacts/runs
run-name = amazon-computers__lafak
save-best = true
wandb-enable = true
wandb-project = gnn-label-poisoning
wandb-tags = amazon_computers,lafak
