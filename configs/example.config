# Core
seed = 42
device = auto

# Dataset
dataset-name = Amazon
dataset-variant = Computers
dataset-root = artifacts/data/amzcomp
dataset-normalize-features = true

# Model (torch_geometric.nn.models)
model-name = gcn
hidden-dim = 64
num-layers = 2
dropout = 0.5
heads = 8

# Attack
attack-name = label_flipping
attack-flip-frac = 0.1
# attack-target-label = none
# attack-apply-to = train
attack-seed = 42

# Train
epochs = 200
lr = 0.01
weight-decay = 5e-4
eval-every = 1

# Logging
run-dir = artifacts/runs
run-name = demo
save-best = true
